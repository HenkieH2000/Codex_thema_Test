{% comment %}
  VCT Init — scroll-reveal stagger + social proof JS
  Include once in theme.liquid just before </body>
{% endcomment %}
<script>
(function(){
  /* ── Scroll-reveal stagger ──────────────────────────────────────── */
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){
        e.target.classList.add('vct-visible');
        io.unobserve(e.target);
      }
    });
  },{threshold:0.08,rootMargin:'0px 0px -40px 0px'});

  function initStagger(){
    document.querySelectorAll('.vct-stagger > *').forEach(function(el,i){
      el.style.transitionDelay = (i * 60) + 'ms';
      io.observe(el);
    });
    document.querySelectorAll('.vct-reveal').forEach(function(el){
      io.observe(el);
    });
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', initStagger);
  } else {
    initStagger();
  }

  var socialProofRoot = document.getElementById('vct-social-proof-root');

  /* ── Live viewer counter ────────────────────────────────────────── */
  var counters = document.querySelectorAll('.vct-viewer-count');
  if(counters.length){
    var viewerMin = socialProofRoot ? parseInt(socialProofRoot.dataset.viewerMin, 10) || 6 : 6;
    var viewerMax = socialProofRoot ? parseInt(socialProofRoot.dataset.viewerMax, 10) || 25 : 25;
    var base = Math.floor(Math.random() * ((viewerMax - viewerMin) + 1)) + viewerMin;
    counters.forEach(function(el){ el.textContent = base; });
    setInterval(function(){
      var delta = Math.random() < 0.5 ? 1 : -1;
      base = Math.max(viewerMin, Math.min(viewerMax, base + delta));
      counters.forEach(function(el){ el.textContent = base; });
    }, 4200);
  }

  /* ── Swiper touch patch ─────────────────────────────────────────── */
  /* Forces touch + correct mobile slidesPerView on all instances.     */
  function patchSwiperTouch(){
    document.querySelectorAll('.swiper').forEach(function(el){
      var sw = el.swiper;
      if(!sw) return;
      /* Force touch on base params */
      sw.params.allowTouchMove = true;
      sw.allowTouchMove        = true;
      sw.params.simulateTouch  = true;
      /* Patch every breakpoint */
      if(sw.params.breakpoints){
        Object.keys(sw.params.breakpoints).forEach(function(bp){
          sw.params.breakpoints[bp].allowTouchMove = true;
          sw.params.breakpoints[bp].simulateTouch  = true;
          /* Mobile breakpoint 0: ensure 2 visible slides so swiping is meaningful */
          if(bp === '0' && !sw.params.breakpoints[bp].slidesPerView){
            sw.params.breakpoints[bp].slidesPerView = 2;
            sw.params.breakpoints[bp].spaceBetween  = 12;
          }
        });
      }
      /* Re-apply so changes are visible immediately */
      try { sw.update(); } catch(e){}
    });
  }
  /* Run at 600ms, 1.5s and 3s to catch sliders that load late */
  setTimeout(patchSwiperTouch, 600);
  setTimeout(patchSwiperTouch, 1500);
  setTimeout(patchSwiperTouch, 3000);

  /* ── Social proof toasts ────────────────────────────────────────── */
  var toastWrap = document.getElementById('vct-sp-toasts');
  if(!toastWrap || !socialProofRoot) return;

  var names = socialProofRoot.dataset.names ? JSON.parse(socialProofRoot.dataset.names) : ['Joris','Sanne','Pieter','Lisa','Mark'];
  var products = socialProofRoot.dataset.products ? JSON.parse(socialProofRoot.dataset.products) : ['een product'];
  var places = socialProofRoot.dataset.places ? JSON.parse(socialProofRoot.dataset.places) : ['Amsterdam','Rotterdam','Utrecht','Eindhoven'];
  var delay = parseInt(socialProofRoot.dataset.delay, 10) || 8000;
  var minInterval = parseInt(socialProofRoot.dataset.minInterval, 10) || 25000;
  var maxInterval = parseInt(socialProofRoot.dataset.maxInterval, 10) || 45000;
  var templateName = socialProofRoot.dataset.template || '';

  if(!products.length || templateName === 'cart' || templateName === 'customers/login'){
    return;
  }

  function randomFrom(arr){ return arr[Math.floor(Math.random()*arr.length)]; }

  function showToast(){
    var t = document.createElement('div');
    t.className = 'vct-sp-toast';
    t.innerHTML =
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>' +
      '<span><strong>' + randomFrom(names) + '</strong> uit ' + randomFrom(places) +
      ' kocht <strong>' + randomFrom(products) + '</strong></span>';
    toastWrap.appendChild(t);
    setTimeout(function(){ t.classList.add('vct-sp-toast--in'); }, 10);
    setTimeout(function(){
      t.classList.remove('vct-sp-toast--in');
      setTimeout(function(){ t.remove(); }, 400);
    }, 4500);
  }

  function scheduleNextToast() {
    var nextDelay = minInterval;
    if (maxInterval > minInterval) {
      nextDelay = Math.floor(Math.random() * (maxInterval - minInterval + 1)) + minInterval;
    }
    setTimeout(function(){
      showToast();
      scheduleNextToast();
    }, nextDelay);
  }

  setTimeout(function(){
    showToast();
    scheduleNextToast();
  }, delay);

})();
</script>
